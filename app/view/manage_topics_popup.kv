<ManageTopicsPopup>:
    title: "Manage Topics"
    title_color: 0, 0, 0, 1
    title_align: "center"
    size_hint: 0.7, 0.7
    auto_dismiss: True
    background_color: 1, 1, 1, 1
    background: ""

    BoxLayout:
        orientation: "vertical"
        padding: 20
        spacing: 15

        ScrollView:
            do_scroll_x: False
            BoxLayout:
                id: topics_list
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: 8

        Button:
            text: "Close"
            size_hint_y: None
            height: "44dp"
            background_normal: ""
            background_color: 0.49, 0.71, 0.84, 1
            on_release: root.dismiss()