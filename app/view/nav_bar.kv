<NavigationBar>:
    id: nav
    screen_manager: None
    orientation: 'horizontal'
    size_hint_y: None
    height: '50dp'
    spacing: '10dp'
    padding: '10dp'
    canvas.before:
        Color:
            rgba: 1, 1, 1, 1
        Rectangle:
            pos: self.pos
            size: self.size

    NavButton:
        text: "Tasks"
        screen_name: "tasks"
        screen_manager: root.screen_manager

    NavButton:
        text: "Planner"
        screen_name: "planner"
        screen_manager: root.screen_manager

    NavButton:
        text: "Notes"
        screen_name: "notes"
        screen_manager: root.screen_manager

    NavButton:
        text: "Pomodoro Timer"
        screen_name: "pomodoro"
        screen_manager: root.screen_manager