<NavButton@Button>:
    screen_name: ""
    screen_manager: None
    background_normal: ""
    background_color: (1,0.8,0.2,1) if self.screen_manager and self.screen_manager.current == self.screen_name else (1,1,0.3,0.5)
    color: 0,0,0,1
    on_release: self.screen_manager and setattr(self.screen_manager, 'current', self.screen_name)